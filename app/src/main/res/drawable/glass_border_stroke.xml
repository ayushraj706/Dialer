<?xml version="1.0" encoding="utf-8"?>
<!--
    GLASSMORPHISM
    A thin, semi-transparent white edge. Real glass/frosted panels always
    have a faint highlighted rim where light catches the edge — this is
    what sells the "glass" look on top of the blur itself.
    Used as android:foreground on the BlurView so it draws over the blur
    but under the tab icons/text (which have their own higher elevation).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="28dp" />
    <stroke
        android:width="1dp"
        android:color="#40FFFFFF" />
</shape>
